# Modo de ejecución:
# - api   => usa LLM real (GitHub Models)
# - rules => usa generador local por reglas (sin API)
LLM_MODE=api

# Modelo principal (Solo GitHub Models)
# Ejemplos:
# MODEL=github/gpt-4o-mini (Recomendado - Gratis y alta calidad)
# MODEL=github/gpt-4.1-mini
MODEL=github/gpt-4o-mini

# Creatividad del modelo
TEMPERATURE=0.5

# Opción avanzada (agnóstica):
# Si defines LLM_API_KEY, se usa esta key sin importar proveedor.
# Si defines LLM_BASE_URL, se usa endpoint compatible OpenAI (útil para GitHub Models/OpenRouter/etc.)
LLM_API_KEY=
LLM_BASE_URL=

# Configura según proveedor que uses (Solo GitHub Models)
GITHUB_TOKEN=
GITHUB_API_KEY=
GH_TOKEN=

# Variable personalizada para producción DigitalOcean
GithubPuenteCultural=
