# Modo de ejecución:
# - api   => usa LLM real (GitHub Models/Gemini)
# - rules => usa generador local por reglas (sin API)
LLM_MODE=api

# Modelo principal (CrewAI/LiteLLM format)
# Ejemplos:
# MODEL=github/gpt-4o-mini (Recomendado - Gratis y alta calidad)
# MODEL=github/gpt-4.1-mini
# MODEL=gemini/gemini-2.0-flash
# MODEL=anthropic/claude-3-5-haiku-latest
MODEL=github/gpt-4o-mini

# Modelo de fallback (si el principal falla)
FALLBACK_MODEL=gemini/gemini-2.0-flash

# Creatividad del modelo
TEMPERATURE=0.5

# Opción avanzada (agnóstica):
# Si defines LLM_API_KEY, se usa esta key sin importar proveedor.
# Si defines LLM_BASE_URL, se usa endpoint compatible OpenAI (útil para GitHub Models/OpenRouter/etc.)
LLM_API_KEY=
LLM_BASE_URL=

# Configura según proveedor que uses
OPENAI_API_KEY=
OPENAI_BASE_URL=
GOOGLE_API_KEY=
GEMINI_API_KEY=
ANTHROPIC_API_KEY=
GITHUB_TOKEN=
GITHUB_API_KEY=
GH_TOKEN=

# Variables personalizadas para producción DigitalOcean
GithubPuenteCultural=
GeminiPuenteCultural=
OpenIaPuenteCultural=
